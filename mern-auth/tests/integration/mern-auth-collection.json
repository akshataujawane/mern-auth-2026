{
  "info": {
    "name": "mern-auth Integration Tests",
    "_postman_id": "mern-auth-cicd-collection",
    "description": "Integration tests for mern-auth API.\nCovers: POST /api/auth/signup | POST /api/auth/signin | GET /api/user | POST /api/auth/signout\nEvidence for PRCICD-002 — Build and Test Code",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",   "value": "http://localhost:9191" },
    { "key": "authToken", "value": "" },
    { "key": "userId",    "value": "" }
  ],
  "item": [
    {
      "name": "1 — Health Check (GET /api/user)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/user"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns API message', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.message).to.eql('API is working!');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2 — Signup (POST /api/auth/signup)",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/signup",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"username\": \"testuser_ci\", \"email\": \"ci_test@mernauth.local\", \"password\": \"Test@1234\" }"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Signup returns 201', () => pm.response.to.have.status(201));",
              "pm.test('Success message present', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.message).to.include('successfully');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3 — Signup Duplicate (POST /api/auth/signup) — expect 500",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/signup",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"username\": \"testuser_ci\", \"email\": \"ci_test@mernauth.local\", \"password\": \"Test@1234\" }"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Duplicate signup returns 4xx/5xx', () => {",
              "  pm.expect(pm.response.code).to.be.within(400, 599);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4 — Signin (POST /api/auth/signin)",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/signin",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"email\": \"ci_test@mernauth.local\", \"password\": \"Test@1234\" }"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Signin returns 200', () => pm.response.to.have.status(200));",
              "pm.test('Response contains user data', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('email');",
              "  pm.expect(body).to.have.property('_id');",
              "  pm.expect(body).not.to.have.property('password');",
              "  pm.collectionVariables.set('userId', body._id);",
              "});",
              "pm.test('access_token cookie is set', () => {",
              "  pm.expect(pm.cookies.has('access_token')).to.be.true;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5 — Wrong Password (POST /api/auth/signin) — expect 401",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/signin",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"email\": \"ci_test@mernauth.local\", \"password\": \"WrongPass!\" }"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Wrong credentials returns 401', () => pm.response.to.have.status(401));"
            ]
          }
        }
      ]
    },
    {
      "name": "6 — Unknown User (POST /api/auth/signin) — expect 404",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/signin",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"email\": \"nobody@notexist.com\", \"password\": \"anything\" }"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Unknown user returns 404', () => pm.response.to.have.status(404));"
            ]
          }
        }
      ]
    },
    {
      "name": "7 — Signout (GET /api/auth/signout)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/auth/signout"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Signout returns 200', () => pm.response.to.have.status(200));",
              "pm.test('Signout success message', () => {",
              "  pm.expect(pm.response.text()).to.include('Signout success');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "8 — Update User Without Auth (POST /api/user/update/:id) — expect 401/403",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/user/update/{{userId}}",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"username\": \"hacked\" }"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Unauthenticated update is blocked', () => {",
              "  pm.expect(pm.response.code).to.be.within(400, 499);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "9 — Frontend SPA catch-all (GET /) — expect 200 HTML",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Frontend SPA returns 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is HTML', () => {",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('text/html');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
