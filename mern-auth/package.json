{
  "name": "mern-auth",
  "version": "1.0.0",
  "description": "MERN authentication service — production-grade, AWS DevOps Competency demo",
  "type": "module",
  "main": "api/index.js",
  "scripts": {
    "dev": "nodemon api/index.js",
    "start": "node api/index.js",
    "build": "npm install && npm install --prefix client && npm run build --prefix client",
    "test": "npm run test --prefix client",
    "test:coverage": "npm run test --prefix client",
    "test:api": "cross-env NODE_ENV=test vitest run",
    "test:api:coverage": "cross-env NODE_ENV=test vitest run --coverage"
  },
  "keywords": [
    "mern",
    "auth",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-prom-bundle": "^7.0.0",
    "jsonwebtoken": "^9.0.1",
    "mongoose": "^9.4.1",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "cross-env": "^10.1.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.4"
  }
}
